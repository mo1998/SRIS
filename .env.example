# Smart Remote Interview System - Environment Configuration
# Copy this file to .env and update with your settings

# ===========================================
# Application Settings
# ===========================================
DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production-use-openssl-rand-hex-32
FRONTEND_URL=http://localhost
ALLOWED_ORIGINS=["http://localhost"]

# ===========================================
# PostgreSQL Database
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-in-production
POSTGRES_PORT=5432

# ===========================================
# Redis Cache
# ===========================================
REDIS_PASSWORD=changeme-in-production
REDIS_PORT=6379

# ===========================================
# OpenAI API (for answer evaluation)
# ===========================================
OPENAI_API_KEY=your-openai-api-key-here

# ===========================================
# Email Configuration (SMTP)
# ===========================================
MAIL_FROM=noreply@yourdomain.com
MAIL_PASSWORD=your-email-password
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# ===========================================
# Port Mappings
# ===========================================
BACKEND_PORT=8000
FRONTEND_PORT=80

# ===========================================
# SSL/TLS (for production)
# ===========================================
# Uncomment and configure for HTTPS
# SSL_CERTIFICATE=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_CERTIFICATE_KEY=/etc/letsencrypt/live/yourdomain.com/privkey.pem
