# Smart Remote Interview System - Local Development Environment
# Copy this file to .env for local Docker/development use.
# For production, start from .env.production.example instead.

# ===========================================
# Application Settings
# ===========================================
DEBUG=True
SECRET_KEY=local-development-secret-key-change-before-production
FRONTEND_URL=http://localhost
ALLOWED_ORIGINS=["http://localhost"]

# ===========================================
# PostgreSQL Database
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ===========================================
# Redis Cache
# ===========================================
REDIS_PASSWORD=redispassword
REDIS_PORT=6379

# ===========================================
# Local LLM Evaluation
# ===========================================
EVALUATION_PROVIDER=local_vllm
EVALUATION_QUEUE_BACKEND=rq
EVALUATION_QUEUE_NAME=evaluation
EVALUATION_PROMPT_VERSION=rubric-v1
LOCAL_LLM_BASE_URL=http://localhost:8100/v1
LOCAL_LLM_MODEL=qwen3-8b-awq
LOCAL_LLM_TIMEOUT_SECONDS=5

# ===========================================
# OpenAI API (legacy; local providers are preferred)
# ===========================================
OPENAI_API_KEY=

# ===========================================
# Email Configuration (Mailpit)
# ===========================================
MAIL_FROM=noreply@yourdomain.com
MAIL_FROM_NAME=SRIS
MAILPIT_API_URL=http://localhost:8025/api/v1/send
INVITATION_RESEND_COOLDOWN_SECONDS=300
MAX_BULK_INVITATIONS=100

# ===========================================
# Port Mappings
# ===========================================
BACKEND_PORT=8000
FRONTEND_PORT=80
MAX_REQUEST_BODY_SIZE=20971520

# ===========================================
# SSL/TLS (for production)
# ===========================================
# Uncomment and configure for HTTPS
# SSL_CERTIFICATE=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
# SSL_CERTIFICATE_KEY=/etc/letsencrypt/live/yourdomain.com/privkey.pem
