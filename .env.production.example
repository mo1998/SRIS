# Smart Remote Interview System - Production Environment Template
# Copy to .env on the production host and replace every CHANGE_ME value.
# DEBUG=False enables startup guardrails.

# ===========================================
# Application Settings
# ===========================================
DEBUG=False
SECRET_KEY=CHANGE_ME_use_openssl_rand_hex_32
FRONTEND_URL=https://sris.example.com
ALLOWED_ORIGINS=["https://sris.example.com"]

# ===========================================
# PostgreSQL Database
# ===========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_postgres_password
POSTGRES_PORT=5432

# ===========================================
# Redis Cache
# ===========================================
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_PORT=6379

# ===========================================
# Local LLM Evaluation
# ===========================================
EVALUATION_PROVIDER=local_vllm
EVALUATION_QUEUE_BACKEND=rq
EVALUATION_QUEUE_NAME=evaluation
EVALUATION_PROMPT_VERSION=rubric-v1
LOCAL_LLM_BASE_URL=http://localhost:8100/v1
LOCAL_LLM_MODEL=qwen3-8b-awq
LOCAL_LLM_TIMEOUT_SECONDS=5

# ===========================================
# Email Configuration
# ===========================================
# For production, use "brevo" provider.
# For local dev with Mailpit, set MAIL_PROVIDER=mailpit and MAILPIT_API_URL.
MAIL_PROVIDER=brevo
MAIL_FROM=interviews@example.com
MAIL_FROM_NAME=SRIS
MAILPIT_API_URL=http://localhost:8025/api/v1/send
BREVO_API_KEY=CHANGE_ME_brevo_api_key
INVITATION_RESEND_COOLDOWN_SECONDS=300
MAX_BULK_INVITATIONS=100

# ===========================================
# Port Mappings
# ===========================================
BACKEND_PORT=8000
FRONTEND_PORT=80
MAX_REQUEST_BODY_SIZE=20971520

# ===========================================
# SSL/TLS (for production)
# ===========================================
SSL_CERTIFICATE=/etc/letsencrypt/live/sris.example.com/fullchain.pem
SSL_CERTIFICATE_KEY=/etc/letsencrypt/live/sris.example.com/privkey.pem